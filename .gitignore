# PyInstaller
#  Usually these files are written by a python script from a template
#  before PyInstaller builds the exe, so as long as they are installed
#  from the clean git checkout they will be fine.
*.manifest
*.spec

# Installer logs
pip-log.txt
pip-delete-this-directory.txt

# Unit test / coverage reports
htmlcov/
.tox/
.nosenv/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.hypothesis/
test-reports/

# Translations
*.mo
*.pot

# Django stuff:
*.log
local_settings.py
db.sqlite3
db.sqlite3-journal

# Sphinx documentation
docs/_build/

# PyBuilder
.pybuilder/
target/

# Jupyter Notebook
.ipynb_checkpoints

# IPython
profile_default/
ipython_config.py

# pyenv
#   For a library or package, you might want to ignore these files since the user is responsible for
#   defining their own environment. But for an application, you might want to track them.
# .python-version

# pipenv
#   According to pypa/pipenv#1255, pipenv should generally not be ignored
#   unless you are standardizing across a team.
#Pipfile.lock

# poetry
#   Using Poetry is similar to Pipenv and lock file should be tracked
#poetry.lock

# pdm
#   Using pdm is similar to Pipenv and lock file should be tracked
#pdm.lock

# virtualenv
.venv
venv/
ENV/
env/

# IDEs and Editors
.idea/
.vscode/
*.swp
*.swo

# Project specific
.env
*.log
.uv
.output
